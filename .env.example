# Salin file ini menjadi .env lalu isi nilainya.

# Catatan: URL webhook N8N diatur per-akun di dalam dashboard (menu Integrations),
# jadi tidak ada env webhook global.

# Cek Ongkir (RajaOngkir via Komerce)
# API Key sekarang disimpan di Backend (Supabase Edge Functions).
# Untuk development lokal, jalankan ini di terminal:
# supabase secrets set RAJAONGKIR_KEY=api_key_kamu

# PIN registrasi admin — user harus masukin PIN ini saat daftar akun baru.
# Ganti sesuai keinginan. Kosong = registrasi terbuka tanpa PIN.
VITE_REGISTER_PIN=

# URL API Ongkir (Arahkan ke server Node.js di VPS nanti, misal: https://dashboard.leyatiofficial.xyz/api/ongkir)
VITE_BACKEND_URL=https://dashboard.leyatiofficial.xyz/api/ongkir

# URL API Utama
VITE_API_URL=https://dashboard.leyatiofficial.xyz/api

# URL Socket.io
VITE_SOCKET_URL=https://dashboard.leyatiofficial.xyz
