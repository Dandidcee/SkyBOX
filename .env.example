# Salin file ini menjadi .env lalu isi nilainya.
# Ambil dari Supabase: Project Settings -> API.
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Gunakan kunci "anon"/"public" SAJA. JANGAN taruh service_role di sini.
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Catatan: URL webhook N8N diatur per-akun di dalam dashboard (menu Integrations),
# jadi tidak ada env webhook global.
